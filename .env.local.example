# ============================================================
# Supabase — from supabase.com project settings > API
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ============================================================
# Google Gemini AI — from aistudio.google.com
# ============================================================
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================
# Notion OAuth — from notion.so/my-integrations
# ============================================================
NOTION_CLIENT_ID=your_notion_oauth_client_id_here
NOTION_CLIENT_SECRET=your_notion_oauth_client_secret_here
NOTION_REDIRECT_URI=http://localhost:3000/api/notion/callback

# ============================================================
# App Config
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SagaNote

# ============================================================
# Admin (your Google account email)
# ============================================================
ADMIN_EMAIL=your_email@gmail.com
